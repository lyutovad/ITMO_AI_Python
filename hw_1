    {
      "cell_type": "code",
      "source": [
        "def count_positive(nums: list[int]) -> int:\n",
        "    count = 0\n",
        "    for x in nums:\n",
        "        if x > 0:\n",
        "            count += 1\n",
        "    return count"
      ],
      "metadata": {
        "id": "qTdcY6JkJx0C"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def sum_even(nums: list[int]) -> int:\n",
        "    total = 0\n",
        "    for x in nums:\n",
        "        if x % 2 == 0:\n",
        "            total += x\n",
        "    return total"
      ],
      "metadata": {
        "id": "04b34TUVJ9Hv"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def first_divisible(nums: list[int], k: int) -> int | None:\n",
        "    found: int | None = None\n",
        "    for x in nums:\n",
        "        if x % k == 0:\n",
        "            found = x\n",
        "            break\n",
        "    return found"
      ],
      "metadata": {
        "id": "XDuCHlgeKANG"
      },
      "execution_count": 6,
      "outputs": []
    },
