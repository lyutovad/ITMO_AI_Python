    {
      "cell_type": "code",
      "source": [
        "nums = [12, -3, 4, 17, -9, 8, 22, -1, 5, 6, -12, 13, 14, 2, 9, -5, 18, 7, 10, -20, 3, 16, -8, 1, 11]"
