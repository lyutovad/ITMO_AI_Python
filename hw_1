    {
      "cell_type": "code",
      "source": [
        "class Chocolate:\n",
        "    def __init__(self, name: str, price: float):\n",
        "        if price <= 0:\n",
        "            raise ValueError(\"Цена должна быть положительной (price > 0).\")\n",
        "        self.name = name\n",
        "        self.price = float(price)\n",
        "\n",
        "    def discount(self, percent: int) -> float:\n",
        "        return self.price * (1 - percent / 100)"
      ],
      "metadata": {
        "id": "FCiJSLhULUOW"
      },
      "execution_count": 12,
      "outputs": []
    },
